<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — NEET Insight</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-color: #F4F7FE;
      --primary: #6366F1;
      --primary-hover: #4F46E5;
      --logo-start: #FF9C00;
      --logo-end: #FFC048;
    }

    * {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    body {
      background: var(--bg-color);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0;
    }

    .login-wrapper {
      width: 100%;
      max-width: 420px;
      padding: 24px;
    }

    .login-card {
      background: #ffffff;
      border-radius: 24px;
      box-shadow: 0 20px 50px rgba(27, 28, 49, 0.08);
      padding: 44px 40px;
    }

    .logo-badge {
      width: 64px;
      height: 64px;
      border-radius: 18px;
      background: linear-gradient(135deg, var(--logo-start), var(--logo-end));
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px auto;
      box-shadow: 0 10px 25px rgba(255, 156, 0, 0.35);
    }

    .logo-badge span {
      color: #ffffff;
      font-weight: 800;
      font-size: 30px;
      line-height: 1;
    }

    .brand-title {
      text-align: center;
      font-weight: 800;
      font-size: 24px;
      color: #1B1C31;
      margin-bottom: 4px;
    }

    .brand-subtitle {
      text-align: center;
      font-size: 14px;
      color: #8A8CA5;
      margin-bottom: 32px;
    }

    .form-label {
      font-weight: 600;
      font-size: 13px;
      color: #1B1C31;
      margin-bottom: 6px;
    }

    .form-control {
      border-radius: 12px;
      border: 1.5px solid #E7E9F5;
      padding: 12px 16px;
      font-size: 14px;
      margin-bottom: 18px;
    }

    .form-control:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
    }

    .btn-login {
      background: var(--primary);
      border: none;
      color: #ffffff;
      font-weight: 600;
      font-size: 15px;
      padding: 12px;
      border-radius: 12px;
      width: 100%;
      transition: background 0.15s ease;
      margin-top: 8px;
    }

    .btn-login:hover {
      background: var(--primary-hover);
      color: #ffffff;
    }

    .alert-error {
      background: #FEF2F2;
      color: #B91C1C;
      border: 1px solid #FECACA;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 13.5px;
      margin-bottom: 20px;
    }

    .footer-note {
      text-align: center;
      font-size: 12.5px;
      color: #ABAECB;
      margin-top: 24px;
    }
  </style>
</head>
<body>
  <div class="login-wrapper">
    <div class="login-card">
      <div class="logo-badge">
        <span>N</span>
      </div>
      <div class="brand-title">NEET Insight</div>
      <div class="brand-subtitle">Test Analysis &amp; Performance Management</div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert-error">
          <%= error %>
        </div>
      <% } %>

      <form action="/login" method="POST">
        <label class="form-label" for="email">Email</label>
        <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" required autofocus>

        <label class="form-label" for="password">Password</label>
        <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required>

        <button type="submit" class="btn-login">Sign In</button>
      </form>

      <div class="footer-note">
        NEET Insight &middot; Analyze. Revise. Improve.
      </div>
    </div>
  </div>
</body>
</html>
