        <div class="chart-card">
          <h3>Accuracy Trend (per test)</h3>
          <canvas id="progressAccuracyChart"></canvas>
        </div>
        <div class="chart-card">
          <h3>Score Trend (per test)</h3>
          <canvas id="progressScoreChart"></canvas>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6">
          <div class="card-box">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:14px;">Weekly Progress</h3>
            <% if (weekly_progress.length === 0) { %>
              <div class="empty-state"><div>No weekly data yet.</div></div>
            <% } else { %>
              <table class="table-custom">
                <thead><tr><th>Week Of</th><th>Tests</th><th>Avg Accuracy</th><th>Avg Score</th></tr></thead>
                <tbody>
                  <% weekly_progress.forEach(w => { %>
                    <tr><td><%= fmtDate(w.week) %></td><td><%= w.tests %></td><td><%= w.avg_accuracy %>%</td><td><%= w.avg_score %></td></tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card-box">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:14px;">Monthly Progress</h3>
            <% if (monthly_progress.length === 0) { %>
              <div class="empty-state"><div>No monthly data yet.</div></div>
            <% } else { %>
              <table class="table-custom">
                <thead><tr><th>Month</th><th>Tests</th><th>Avg Accuracy</th><th>Avg Score</th></tr></thead>
                <tbody>
                  <% monthly_progress.forEach(m => { %>
                    <tr><td><%= m.month_label %></td><td><%= m.tests %></td><td><%= m.avg_accuracy %>%</td><td><%= m.avg_score %></td></tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>
      </div>

      <script>
        const progressTrendData = <%- JSON.stringify(progress_trend) %>;

        new Chart(document.getElementById('progressAccuracyChart'), {
          type: 'line',
          data: {
            labels: progressTrendData.map(d => d.test_name),
            datasets: [{
              label: 'Accuracy %',
              data: progressTrendData.map(d => d.accuracy),
              borderColor: '#16A34A',
              backgroundColor: 'rgba(22,163,74,0.12)',
              fill: true, tension: 0.35, pointRadius: 3
            }]
          },
          options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, max: 100 } } }
        });

        new Chart(document.getElementById('progressScoreChart'), {
          type: 'line',
          data: {
            labels: progressTrendData.map(d => d.test_name),
            datasets: [{
              label: 'Score',
              data: progressTrendData.map(d => d.score),
              borderColor: '#6366F1',
              backgroundColor: 'rgba(99,102,241,0.12)',
              fill: true, tension: 0.35, pointRadius: 3
            }]
          },
          options: { responsive: true, plugins: { legend: { display: false } } }
        });
      </script>

    <% } %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
